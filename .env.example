# Base de données PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/publivite"

# Redis (pour les tâches planifiées)
REDIS_URL="redis://localhost:6379"

# Clé de chiffrement (générer avec : openssl rand -base64 32)
ENCRYPTION_KEY="your_encryption_key_minimum_32_characters"

# NextAuth (pour l'authentification)
NEXTAUTH_SECRET="your_nextauth_secret_minimum_32_characters"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (optionnel)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Playwright
PLAYWRIGHT_HEADLESS="true"

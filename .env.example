# ===========================================
# PUBLIVITE - Configuration d'environnement
# ===========================================
# Copiez ce fichier en .env.local et remplissez les valeurs

# Base de données PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/lbcmanager?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="votre-secret-nextauth-generer-une-cle-aleatoire"

# Redis (pour BullMQ)
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD=""

# Chiffrement des identifiants Leboncoin
# Générer avec: openssl rand -hex 32
ENCRYPTION_KEY="votre-cle-de-chiffrement-32-caracteres-hex"

# Playwright - Chemin vers les navigateurs
PLAYWRIGHT_BROWSERS_PATH="/home/ubuntu/.playwright-browsers"
# PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH="/path/to/chrome" # Optionnel

# Mode de développement
NODE_ENV="development"

# ===========================================
# Configuration optionnelle pour la production
# ===========================================

# Proxy pour Playwright (optionnel)
# LEBONCOIN_PROXY_SERVER="http://proxy.example.com:8080"
# LEBONCOIN_PROXY_USERNAME=""
# LEBONCOIN_PROXY_PASSWORD=""

# Limites de rate (optionnel, valeurs par défaut utilisées si non définies)
# LEBONCOIN_MAX_CONCURRENT="2"
# LEBONCOIN_MIN_DELAY_MS="30000"
# LEBONCOIN_MAX_ADS_PER_HOUR="10"
# LEBONCOIN_MAX_ADS_PER_DAY="50"

# =============================================================================
# .dockerignore - Optimisation du contexte de build Docker
# =============================================================================

# Dépendances (reconstruites dans le conteneur)
node_modules
.pnp
.pnp.js

# Build outputs (reconstruits dans le conteneur)
.next
out
build
dist

# Git
.git
.gitignore
.gitattributes

# Fichiers d'environnement (secrets)
.env
.env.*
!.env.example

# IDE et éditeurs
.idea
.vscode
*.swp
*.swo
*~
.DS_Store

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Tests
coverage
.nyc_output
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
__tests__

# Documentation
README.md
CHANGELOG.md
CONTRIBUTING.md
LICENSE
docs

# Uploads utilisateur (données persistantes)
uploads/screenshots
uploads/images/*
!uploads/images/.gitkeep

# Fichiers Docker (éviter la récursion)
Dockerfile*
docker-compose*
.docker

# CI/CD
.github
.gitlab-ci.yml
.travis.yml
Jenkinsfile

# Outils de développement
.husky
.eslintcache
.prettierrc*
.editorconfig
tsconfig.tsbuildinfo

# Fichiers temporaires
tmp
temp
*.tmp
*.temp

# Cache
.cache
.turbo

# Fichiers Abacus
.abacus.*

# Misc
*.md
!README.md
Makefile
